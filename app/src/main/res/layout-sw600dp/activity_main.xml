<?xml version="1.0" encoding="utf-8"?>
<!-- Layout optimizado para tablets y pantallas grandes (>600dp) -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E1A"
    tools:context=".MainActivity">

    <!-- Header con estadísticas - igual que en phones -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#15192A"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/logo_sigint_radar"
                android:contentDescription="SIGINT Radar Logo"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SIGINT RADAR"
                android:textColor="#00FF41"
                android:textSize="24sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:layout_marginStart="12dp"/>
        </LinearLayout>

        <!-- Estadísticas en horizontal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="8dp"
                android:background="#1A1E2E">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DEVICES"
                    android:textColor="#00FF4180"
                    android:textSize="10sp"
                    android:fontFamily="monospace"/>

                <TextView
                    android:id="@+id/totalDevicesText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#00FF41"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <View
                android:layout_width="8dp"
                android:layout_height="0dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:orientation="vertical"
                android:padding="8dp"
                android:background="#1A1E2E">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RISK LEVELS"
                    android:textColor="#00FF4180"
                    android:textSize="10sp"
                    android:fontFamily="monospace"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:id="@+id/criticalCountText"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#FF0000"
                        android:textSize="12sp"
                        android:fontFamily="monospace"/>

                    <TextView
                        android:id="@+id/highCountText"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#FF6600"
                        android:textSize="12sp"
                        android:fontFamily="monospace"/>

                    <TextView
                        android:id="@+id/mediumCountText"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#FFAA00"
                        android:textSize="12sp"
                        android:fontFamily="monospace"/>

                    <TextView
                        android:id="@+id/lowCountText"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#00FF00"
                        android:textSize="12sp"
                        android:fontFamily="monospace"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/wifiCountText"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="WiFi: 0"
                android:textColor="#00FF41"
                android:textSize="12sp"
                android:fontFamily="monospace"/>

            <TextView
                android:id="@+id/bluetoothCountText"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="BLE: 0"
                android:textColor="#00FF41"
                android:textSize="12sp"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <TextView
            android:id="@+id/scanStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFAA00"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_marginTop="4dp"
            android:visibility="gone"
            tools:text="⏳ WiFi scan throttled by Android - showing cached results"/>
    </LinearLayout>

    <!-- Guideline vertical para dividir radar y lista -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/verticalGuideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.55"/>

    <!-- Radar View - Lado izquierdo en tablets -->
    <com.sigint.radar.ui.RadarView
        android:id="@+id/radarView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintBottom_toTopOf="@id/buttonLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/verticalGuideline"/>

    <!-- Lista de dispositivos - Lado derecho en tablets -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/deviceRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#0A0E1A"
        android:padding="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintBottom_toTopOf="@id/buttonLayout"
        app:layout_constraintStart_toEndOf="@id/verticalGuideline"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Guideline horizontal (no usado en tablets pero requerido por el código) -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/radarGuideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.70"/>

    <!-- Botones de control -->
    <LinearLayout
        android:id="@+id/buttonLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#15192A"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/scanButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="56dp"
            android:text="Start Scan"
            android:textColor="#000000"
            android:textStyle="bold"
            android:backgroundTint="#00FF41"
            android:textSize="15sp"
            android:fontFamily="monospace"
            android:layout_marginEnd="8dp"
            android:contentDescription="Iniciar o detener escaneo"/>

        <Button
            android:id="@+id/menuButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="☰"
            android:textSize="28sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2E1A3E"
            android:layout_marginEnd="8dp"
            android:contentDescription="Menu"/>

        <Button
            android:id="@+id/helpButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="@string/help_icon"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#0088FF"
            android:contentDescription="@string/help_button"/>
    </LinearLayout>

    <!-- FABs (no usados en tablets pero mantenidos para compatibilidad) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabMore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/buttonLayout"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabStats"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/fabMore"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabHeatMap"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/fabStats"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabShare"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/fabHeatMap"/>

</androidx.constraintlayout.widget.ConstraintLayout>

