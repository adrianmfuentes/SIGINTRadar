    <!-- Help System -->
    <string name="help_title">SIGINT Radar - Help</string>
    <string name="help_content">
        <![CDATA[
        <b>What is SIGINT Radar?</b><br/>
        Application to detect nearby WiFi and Bluetooth devices and assess potential privacy risks.<br/><br/>

        <b>Risk Levels:</b><br/>
        🔴 <font color="#FF1744">CRITICAL</font>: High-risk device detected<br/>
        🟠 <font color="#FF5252">HIGH</font>: Considerable risk<br/>
        🟡 <font color="#FFB300">MEDIUM</font>: Moderate risk<br/>
        🟢 <font color="#00E676">LOW</font>: Low or normal risk<br/><br/>

        <b>How to use:</b><br/>
        1. Press "Start Scan" to begin scanning<br/>
        2. The radar view will show nearby devices<br/>
        3. The bottom list shows details of each device<br/>
        4. Tap any device to see complete information<br/><br/>

        <b>Buttons:</b><br/>
        • <font color="#00E676">Green</font>: Start/Stop scanning<br/>
        • <font color="#2979FF">?</font>: Help (this dialog)<br/>
        • 🐛: Debug mode (simulated data)<br/>
        • ⚙: Search filters<br/><br/>

        <b>Privacy:</b><br/>
        This app requires location and Bluetooth permissions to function. No information is sent to external servers.
        ]]>
    </string>

