<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:maxHeight="400dp"
    android:background="#15192A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Mensaje -->
        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Found X device(s)\n\nChoose action:"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:paddingBottom="16dp"
            android:gravity="center"/>

        <!-- Botón Save Both -->
        <Button
            android:id="@+id/btnSaveBoth"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="💾 Save Both (JSON + CSV)"
            android:textColor="#FFFFFF"
            android:backgroundTint="#00AA00"
            android:layout_marginBottom="8dp"
            android:textSize="13sp"/>

        <!-- Botón Save JSON -->
        <Button
            android:id="@+id/btnSaveJson"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="📄 Save JSON"
            android:textColor="#FFFFFF"
            android:backgroundTint="#0066AA"
            android:layout_marginBottom="8dp"
            android:textSize="13sp"/>

        <!-- Botón Save CSV -->
        <Button
            android:id="@+id/btnSaveCsv"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="📊 Save CSV"
            android:textColor="#FFFFFF"
            android:backgroundTint="#0066AA"
            android:layout_marginBottom="8dp"
            android:textSize="13sp"/>

        <!-- Botón History Only -->
        <Button
            android:id="@+id/btnHistoryOnly"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="📁 History Only"
            android:textColor="#FFFFFF"
            android:backgroundTint="#555555"
            android:layout_marginBottom="8dp"
            android:textSize="13sp"/>

        <!-- Botón Discard -->
        <Button
            android:id="@+id/btnDiscard"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/discard_stop"
            android:textColor="#FFFFFF"
            android:backgroundTint="#AA0000"
            android:layout_marginBottom="16dp"
            android:textSize="13sp"/>

        <!-- Separador -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginBottom="16dp"/>

        <!-- Botón Continue -->
        <Button
            android:id="@+id/btnContinue"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="↩️ Continue Scanning"
            android:textColor="#000000"
            android:backgroundTint="#00FF41"
            android:textStyle="bold"
            android:textSize="14sp"/>

    </LinearLayout>
</ScrollView>

