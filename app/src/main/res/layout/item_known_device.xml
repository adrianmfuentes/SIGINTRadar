<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#1A1A1A"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvDeviceName"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Device Name"
            android:textColor="#00FF00"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tvTrustBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UNKNOWN"
            android:textColor="#000000"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:background="@drawable/risk_badge"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvMacAddress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AA:BB:CC:DD:EE:FF"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:layout_marginTop="4dp"/>

    <TextView
        android:id="@+id/tvMeta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Seen 1 time | Last seen just now"
        android:textColor="#B0B8C8"
        android:textSize="11sp"
        android:layout_marginTop="2dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/btnCycleTrust"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="40dp"
            android:text="Change Trust"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2E1A3E"/>

        <Button
            android:id="@+id/btnToggleAlert"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="40dp"
            android:text="🔕 Alerts Off"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1A3E3E"
            android:layout_marginStart="8dp"/>

        <Button
            android:id="@+id/btnDelete"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="40dp"
            android:text="🗑 Delete"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#3E1A1A"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

</LinearLayout>
